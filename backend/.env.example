# 服务器配置
PORT=3001
NODE_ENV=development

# 数据库配置
# DB_TYPE: sqlite | mysql | postgres
DB_TYPE=sqlite

# SQLite (only used when DB_TYPE=sqlite)
DB_PATH=./data/marketplace.db

# MySQL / PostgreSQL (only used when DB_TYPE=mysql or postgres)
DB_HOST=127.0.0.1
DB_PORT=3306        # MySQL: 3306, PostgreSQL: 5432
DB_NAME=clawbench
DB_USER=root
DB_PASSWORD=

# JWT 配置
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRES_IN=7d

# 文件存储配置
STORAGE_TYPE=local
STORAGE_PATH=./uploads

# 日志配置
LOG_LEVEL=info
LOG_DIR=./logs

# AI 配置（服务端内置模型，供 AI 助手内置模型列表使用）
# 格式：JSON 数组字符串；每个对象包含 id/name/provider/endpoint/apiKey，可选 maxTokens/apiVersion
# provider 示例：openai | azure-openai | claude | google
AI_BUILTIN_MODELS='[{"id":"gpt-4o-mini","name":"GPT-4o Mini","provider":"openai","endpoint":"https://api.openai.com/v1","apiKey":"your-openai-api-key","maxTokens":4096}]'

# 飞书 OAuth 配置
FEISHU_APP_ID=your-feishu-app-id
FEISHU_APP_SECRET=your-feishu-app-secret
FEISHU_REDIRECT_URI=http://localhost:3001/api/v1/auth/feishu/callback

# Backend API base URL
# prod api base url http://your-backend-domain/api/v1
VITE_API_BASE_URL=http://localhost:3001/api/v1

# Note: Feishu OAuth configuration has been moved to the backend.
# See backend/.env.example for FEISHU_APP_ID, FEISHU_APP_SECRET, FEISHU_REDIRECT_URI.

# 是否启用账密登录（设为 false 关闭，仅保留三方登录）
VITE_ENABLE_ACCOUNT_LOGIN=true

# ---------------------------------------------------------------------------
# build:upload:* 脚本上传凭证（不需要 VITE_ 前缀，仅在 Node.js 脚本中使用）
# ---------------------------------------------------------------------------
# 方式一：直接填入已有的 JWT token（最高优先级）
# UPLOAD_TOKEN=eyJhbGciOiJIUzI1NiIs...

# 方式二（推荐，无需配置）：在本地已通过 ClawBench 桌面端登录后，
# 脚本会自动读取登录凭证，无需填写任何内容。

# 方式三：填入账号密码，脚本自动登录获取 token（方式一/二都不存在时使用）
# UPLOAD_USERNAME=your_username
# UPLOAD_PASSWORD=your_password